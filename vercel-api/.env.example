AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=deepseek-v4-flash
AMAP_WEB_KEY=

# Recipe APIs run as a cascade. Default: search mxnzp first, then Wanwei.
RECIPE_API_PRIORITY=mxnzp,wanwei
MXNZP_RECIPE_SEARCH_URL=https://www.mxnzp.com/api/cookbook/search
MXNZP_RECIPE_DETAIL_URL=https://www.mxnzp.com/api/cookbook/details
MXNZP_APP_ID=
MXNZP_APP_SECRET=
WANWEI_RECIPE_BASE_URL=https://route.showapi.com
WANWEI_APP_KEY=

# Optional. If set, clients must send X-App-Token with the same value.
APP_API_TOKEN=
